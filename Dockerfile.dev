# syntax=docker/dockerfile:1

################################################################################
# Etapa deps
FROM eclipse-temurin:21-jdk-jammy as deps

WORKDIR /build

# Copy the mvnw wrapper with executable permissions.
COPY --chmod=0755 mvnw mvnw
COPY .mvn/ .mvn/

# Descargar dependencias (cachea ~/.m2)
RUN --mount=type=bind,source=pom.xml,target=pom.xml \
    --mount=type=cache,target=/root/.m2 \
    ./mvnw dependency:go-offline -DskipTests

################################################################################
# Etapa package
FROM deps as package

WORKDIR /build

COPY ./src src/
RUN --mount=type=bind,source=pom.xml,target=pom.xml \
    --mount=type=cache,target=/root/.m2 \
    ./mvnw package -DskipTests && \
    mv target/$(./mvnw help:evaluate -Dexpression=project.artifactId -q -DforceStdout)-$(./mvnw help:evaluate -Dexpression=project.version -q -DforceStdout).jar target/app.jar

################################################################################
# Etapa extract
FROM package as extract

WORKDIR /build
RUN java -Djarmode=layertools -jar target/app.jar extract --destination target/extracted

################################################################################
# Etapa final (dev con inotify + osmium)
FROM eclipse-temurin:21-jdk-jammy AS final

# Herramientas necesarias: bash, inotify para hot-reload, curl + certs + osmium para scripts
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash inotify-tools curl ca-certificates osmium-tool \
    && rm -rf /var/lib/apt/lists/*

# Usuario no root con UID parametrizable (igualamos al host para que los volúmenes queden con tus permisos)
ARG UID=1000
ARG GID=1000
RUN groupadd -g "${GID}" appgroup || true \
 && useradd -ms /bin/bash -u "${UID}" -g "${GID}" appuser

# EntryPoint
COPY --chmod=0755 docker-entrypoint.dev.sh /docker-entrypoint.sh

USER appuser
WORKDIR /app
ENV HOME=/home/appuser

# Capas extraídas (si querés usar JarLauncher después)
COPY --from=extract /build/target/extracted/dependencies/ ./
COPY --from=extract /build/target/extracted/snapshot-dependencies/ ./
COPY --from=extract /build/target/extracted/spring-boot-loader/ ./
COPY --from=extract /build/target/extracted/application/ ./

# Maven Wrapper para entrypoint (spring-boot:run)
COPY --chmod=0755 mvnw ./mvnw
COPY .mvn/ .mvn/

# Copiar scripts dentro de la imagen y asegurar +x (en dev los podés bind-montar igual)
COPY scripts/ /app/scripts/
RUN chmod +x /app/scripts/*.sh || true

EXPOSE 8080
EXPOSE 35729

ENTRYPOINT ["/docker-entrypoint.sh"]